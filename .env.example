# Database
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# Hack Club Auth — register at auth.hackclub.com
HACKCLUB_AUTH_CLIENT_ID=
HACKCLUB_AUTH_CLIENT_SECRET=
HACKCLUB_AUTH_REDIRECT_URI=http://localhost:5173/auth

# Cohort date range (inclusive, YYYY-MM-DD) — album pages outside this range return 404
COHORT_START=
COHORT_END=

# Access control (comma-separated Slack user IDs)
WHITELIST_IDS=
ADMIN_IDS=

# Hack Club CDN — token from cdn.hackclub.com
HACKCLUB_CDN_TOKEN=

# Hack Club Photos — event ID and global admin key from photos.hackclub.com
HACKCLUB_PHOTOS_EVENT_ID=
HACKCLUB_PHOTOS_ADMIN_API_KEY=

# Slack bot token — needs users:read scope in the Hack Club workspace
SLACK_BOT_TOKEN=

# Web Push — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
# Exposed to the browser (must equal VAPID_PUBLIC_KEY)
PUBLIC_VAPID_PUBLIC_KEY=

# Cron endpoint auth — any random secret
CRON_SECRET=

# adapter-node: required when behind a reverse proxy (Coolify, nginx, etc.)
ORIGIN=http://localhost:5173
PROTOCOL_HEADER=x-forwarded-proto
HOST_HEADER=x-forwarded-host
BODY_SIZE_LIMIT=15728640
